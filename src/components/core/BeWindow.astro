---
interface Props {
  id: string;
  title: string;
  width?: string;
  height?: string;
  top?: string;
  left?: string;
  right?: string;
  initialVisible?: boolean;
  overflowHidden?: boolean;
}

const {
  id,
  title,
  width = "300px",
  height = "200px",
  top = "100px",
  left,
  right,
  initialVisible = false,
  overflowHidden = false,
} = Astro.props;

const positionStyle = left ? `left: ${left};` : right ? `right: ${right};` : "left: 100px;";
---

<div
  id={`window-${id}`}
  class="be-window absolute bg-be-grey border border-be-black flex-col pointer-events-auto"
  style={`width: ${width}; height: ${height}; top: ${top}; ${positionStyle} display: ${initialVisible ? "flex" : "none"}; z-index: 100; box-shadow: 1px 1px var(--be-white), -1px -1px var(--be-shadow);`}
  role="dialog"
  aria-labelledby={`window-title-${id}`}
>
  <div class="window-tab absolute -top-[24px] -left-[1px] h-[24px] min-w-[120px] bg-[#cbcbcb] border border-be-black border-b-0 px-2 flex items-center cursor-move z-10 be-window-tab-clip">
    <div
      class="be-window-close absolute left-[6px] top-[5px] w-[12px] h-[12px] bg-inherit border border-be-black shadow-[inset:1px_1px_var(--be-white)] cursor-pointer hover:shadow-[inset:1px_1px_var(--be-black)] focus-visible:outline-2 focus-visible:outline-be-yellow focus-visible:outline-offset-1"
      data-close={id}
      role="button"
      aria-label="Close window"
      tabindex="0"
    ></div>
    <div id={`window-title-${id}`} class="window-title font-bold text-be-black whitespace-nowrap select-none ml-6 mr-8">{title}</div>
  </div>

  <div class="be-window-content-wrapper p-1 flex-1 flex flex-col min-h-0">
    <div class={`be-window-content bg-be-grey border-2 border-be-shadow shadow-[1px_1px_var(--be-white),-1px_-1px_var(--be-shadow)] p-[10px] h-full ${overflowHidden ? 'overflow-hidden' : 'overflow-auto'}`}>
      <slot />
    </div>
  </div>
</div>

<script>
  import "../../scripts/windowManager";
</script>

<style>
  .be-window.focused {
    box-shadow: 2px 2px 10px rgba(0,0,0,0.3), 1px 1px var(--be-white), -1px -1px var(--be-shadow) !important;
  }

  .be-window.focused .window-tab {
    background-color: var(--be-yellow);
  }

  .be-window-close:active {
    box-shadow: inset 1px 1px var(--be-black) !important;
  }
</style>
