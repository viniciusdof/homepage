---
import BeWindow from "../core/BeWindow.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BeWindow
  id="stats"
  title={t("nav.stats")}
  width="200px"
  height="120px"
  top="50px"
  left="800px"
>
  <div class="bg-white be-well p-3 text-center font-mono" id="stats-container">
    <p class="text-sm">
      {t("stats.visitors")}: <span id="visitor-count" class="font-bold" style="contain: layout paint; display: inline-block; min-width: 20px;">...</span>
    </p>
    <p class="text-[10px] text-be-shadow mt-2">
      {t("stats.load")}: <span id="load-pct" style="contain: layout paint; display: inline-block; min-width: 15px;">2</span>%
    </p>
  </div>
</BeWindow>

<script>
  function setIsolatedText(el: HTMLElement, text: string) {
    if (!el.shadowRoot) {
      const shadow = el.attachShadow({ mode: 'open' });
      const span = document.createElement('span');
      span.id = 'inner';
      shadow.appendChild(span);
    }
    const inner = el.shadowRoot!.getElementById('inner')!;
    if (inner.textContent !== text) {
      inner.textContent = text;
    }
  }

  async function updateStats() {
    try {
      const hasCounted = sessionStorage.getItem("counted_visit");
      const url = hasCounted ? "/api/stats" : "/api/stats?inc=true";

      const res = await fetch(url);
      const data = await res.json();
      const countEl = document.getElementById("visitor-count");
      if (countEl && data.visitors) {
        setIsolatedText(countEl, String(data.visitors));
        sessionStorage.setItem("counted_visit", "true");
      }
    } catch (e) {
      console.error("Failed to load stats", e);
    }
  }

  function updateLoad() {
    const loadEl = document.getElementById("load-pct");
    if (loadEl) {
      const newLoad = String(Math.floor(Math.random() * 5) + 1);
      setIsolatedText(loadEl, newLoad);
    }
  }

  const container = document.getElementById('stats-container');
  if (container && !container.dataset.initialized) {
    container.dataset.initialized = 'true';
    updateStats();
    setInterval(updateLoad, 3000);
  }
</script>
