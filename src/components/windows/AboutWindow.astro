---
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import BeButton from "../core/BeButton.astro";
import BeWindow from "../core/BeWindow.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BeWindow
  id="about"
  title={t("nav.profile")}
  width="300px"
  height="auto"
  top="80px"
  left="120px"
  initialVisible={false}
>
  <div class="flex flex-col items-center text-center">
    <Image
      src="/img/viniciusdof.svg"
      width={80}
      height={80}
      class="w-20 h-20 border border-black mb-3 bg-white"
      alt="@viniciusdof's Profile avatar"
      loading="eager"
    />
    <h2 class="text-base font-bold mb-1">@viniciusdof</h2>
    <p class="text-xs mb-3">{t("profile.role")}</p>
    <hr class="w-full border-t border-be-shadow mb-3" />

    <div
      id="now-playing"
      class="w-full mb-4 bg-black p-2 border border-black shadow-[inset_2px_2px_5px_black,1px_1px_white] relative overflow-hidden group min-h-[66px] flex items-center justify-center"
      role="status"
      aria-live="polite"
      aria-label="Last.fm Now Playing Status"
    >
      <div
        id="np-content"
        class="flex items-center gap-3 relative z-10 w-full hidden"
      >
        <div class="relative flex-shrink-0">
          <Image
            id="np-image"
            src="/img/32x32/cdplayer.png"
            alt="Album cover"
            width={48}
            height={48}
            class="w-12 h-12 border border-be-yellow/30 grayscale contrast-125 brightness-75"
            loading="eager"
          />
          <div
            id="np-indicator"
            class="absolute -top-1 -right-1 w-2 h-2 bg-be-yellow rounded-full shadow-[0_0_8px_#fed300] hidden"
            aria-hidden="true"
          >
          </div>
        </div>
        <div class="flex flex-col text-left overflow-hidden">
          <span
            id="np-status"
            class="text-[7px] uppercase font-mono text-be-yellow/70 leading-none mb-1 tracking-tighter"
            style="contain: layout paint; display: inline-block; min-width: 50px;"
          ></span>
          <div class="overflow-hidden whitespace-nowrap">
            <span
              id="np-name"
              class="text-[11px] font-mono font-bold text-be-yellow drop-shadow-[0_0_2px_rgba(254,211,0,0.5)] block truncate"
              style="contain: layout paint;"
            ></span>
          </div>
          <span
            id="np-artist"
            class="text-[9px] font-mono text-be-yellow/90 truncate"
            style="contain: layout paint; display: block;"
          ></span>
        </div>
      </div>

      <div
        id="np-loading"
        class="flex flex-col items-center justify-center z-10"
      >
        <span class="text-[7px] font-mono text-be-yellow/50 uppercase mb-1"
          >System Loading...</span
        >
        <span
          id="np-loading-msg"
          class="text-[9px] font-mono text-be-yellow italic"
          aria-label="Loading message"
          >RETRIEVING VIBES...</span
        >
      </div>

      <div
        class="absolute inset-0 bg-[linear-gradient(rgba(254,211,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(254,211,0,0.03)_1px,transparent_1px)] bg-[size:3px_3px] pointer-events-none"
      >
      </div>
    </div>
    <hr class="w-full border-t border-be-shadow mb-3" />

    <div class="w-full space-y-2 text-left">
      <BeButton
        href="https://bandcamp.com/viniciusdof"
        target="_blank"
        aria-label="Visit @viniciusdof on Bandcamp"
        class="text-[10px]">&bull; Bandcamp</BeButton
      >
      <BeButton
        href="https://last.fm/user/viniciusdof"
        target="_blank"
        aria-label="Visit @viniciusdof on Last.fm"
        class="text-[10px]">&bull; Last.fm</BeButton
      >
      <BeButton
        href="https://letterboxd.com/viniciusdof"
        target="_blank"
        aria-label="Visit @viniciusdof on Letterboxd"
        class="text-[10px]">&bull; Letterboxd</BeButton
      >
      <BeButton
        href="https://discogs.com/user/viniciusdof"
        target="_blank"
        aria-label="Visit @viniciusdof on Discogs"
        class="text-[10px]">&bull; Discogs</BeButton
      >
      <BeButton
        href="https://codeberg.org/viniciusdof/"
        target="_blank"
        aria-label="Visit @viniciusdof on Codeberg"
        class="text-[10px]">&bull; Codeberg</BeButton
      >
    </div>
  </div>
</BeWindow>

<script>
  function setAboutIsolatedText(el: HTMLElement, text: string) {
    if (!el.shadowRoot) {
      const shadow = el.attachShadow({ mode: 'open' });
      const span = document.createElement('span');
      span.id = 'inner';
      shadow.appendChild(span);
    }
    const inner = el.shadowRoot!.getElementById('inner')!;
    if (inner.textContent !== text) {
      inner.textContent = text;
    }
  }

  async function updateLastFM() {
    const npWidget = document.getElementById("now-playing");
    const npContent = document.getElementById("np-content");
    const npLoading = document.getElementById("np-loading");
    const npLoadingMsg = document.getElementById("np-loading-msg");

    if (!npWidget || !npContent || !npLoading) {
      return;
    }

    const lang = document.documentElement.lang || "pt-br";
    const isEn = lang.startsWith("en");
    const isEs = lang.startsWith("es");

    const messages = isEn
      ? [
          "RETRIEVING SONIC VIBES...",
          "INTERROGATING LAST.FM...",
          "GAZING AT SHOES...",
          "ADJUSTING INFINITE REVERB...",
          "SEARCHING FOR THE PERFECT PEDAL...",
          "CRANKING UP THE WALL OF SOUND...",
          "SNIFFING AIRWAVES...",
          "SCANNING DISC ROTATION...",
        ]
      : isEs
        ? [
            "RECUPERANDO VIBRACIONES...",
            "MIRANDO LAS ZAPATILLAS...",
            "AJUSTANDO EL REVERB INFINITO...",
            "BUSCANDO EL PEDAL PERFECTO...",
            "CARGANDO DATOS AUDITIVOS...",
            "LLAMANDO MODEM BEOS...",
            "ESCANEANDO DISCO...",
          ]
        : [
            "SCROBBLANDO ATÉ O TALO...",
            "OLHANDO PARA O TÊNIS...",
            "AJUSTANDO O REVERB INFINITO...",
            "PROCURANDO O PEDAL PERDIDO...",
            "AUMENTANDO O WALL OF SOUND...",
            "SINCROBBLANDO OS DADOS...",
            "VERIFICANDO SE É POSER...",
            "CARREGANDO A SOFRÊNCIA...",
            "DISCANDO PARA O MODEM...",
          ];

    if (npLoadingMsg) {
      setAboutIsolatedText(npLoadingMsg, messages[Math.floor(Math.random() * messages.length)]);
    }

    try {
      const response = await fetch("/api/lastfm");
      const data = await response.json();

      if (data.error) {
        npWidget.classList.add("hidden");
        return;
      }

      const img = document.getElementById("np-image") as HTMLImageElement;
      const name = document.getElementById("np-name");
      const artist = document.getElementById("np-artist");
      const status = document.getElementById("np-status");
      const indicator = document.getElementById("np-indicator");

      if (img) {
        img.src = data.image || "/img/32x32/cdplayer.png";
        img.alt = data.nowPlaying 
          ? `Now playing: ${data.name} by ${data.artist}`
          : `Last played: ${data.name} by ${data.artist}`;
      }
      if (name) {
        setAboutIsolatedText(name, data.name);
      }
      if (artist) {
        setAboutIsolatedText(artist, data.artist);
      }

      if (status) {
        let statusText = "";
        if (data.nowPlaying) {
          statusText = isEn
            ? "Now Playing"
            : isEs
              ? "Escuchando ahora"
              : "Ouvindo agora";
          indicator?.classList.remove("hidden");
        } else {
          statusText = isEn
            ? "Last Scrobble"
            : isEs
              ? "Última escuchada"
              : "Última ouvida";
          indicator?.classList.add("hidden");
        }
        setAboutIsolatedText(status, statusText);
      }

      npLoading.classList.add("hidden");
      npContent.classList.remove("hidden");
    } catch (e) {
      console.error("Last.fm fetch failed", e);
      npWidget.classList.add("hidden");
    }
  }

  const npWidget = document.getElementById("now-playing");
  if (npWidget && !npWidget.dataset.initialized) {
    npWidget.dataset.initialized = "true";
    updateLastFM();
    setInterval(updateLastFM, 60000);
  }
</script>
