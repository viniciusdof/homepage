---
import { Image } from "astro:assets";
import BeWindow from "../core/BeWindow.astro";
import BeButton from "../core/BeButton.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BeWindow
  id="trash"
  title={t("nav.trash")}
  width="250px"
  height="200px"
  top="450px"
  left="400px"
>
  <div class="flex flex-col items-center justify-center h-full text-center space-y-4">
    <Image src="/img/32x32/trash.png" width={64} height={64} class="w-16 h-16" alt="Trash" />
    <p class="text-xs">{t("trash.empty")}</p>
    <BeButton id="empty-trash-btn" class="text-[10px] px-4 py-1">{t("trash.button")}</BeButton>
  </div>
</BeWindow>

<script>
  import { triggerPanic } from "../../scripts/panicMode";

  document.getElementById("empty-trash-btn")?.addEventListener("click", () => {
    triggerPanic();
  });
</script>
