---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import Guestbook from "../apps/Guestbook.astro";
import BeWindow from "../core/BeWindow.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BeWindow
  id="guestbook"
  title={t("guestbook.title")}
  width="350px"
  height="450px"
  top="100px"
  right="380px"
>
  <Guestbook />
</BeWindow>
